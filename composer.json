{
    "name": "chr15k/laravel-meilisearch-advanced-query",
    "description": "A fluent query builder for Meilisearch filter expressions in Laravel.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "chr15k",
        "search",
        "scout",
        "php",
        "meilisearch",
        "advanced query"
    ],
    "authors": [
        {
            "name": "Chris Keller",
            "email": "ctk8501@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "laravel/scout": "^11.0",
        "meilisearch/meilisearch-php": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.11|^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.2",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Chr15k\\MeilisearchAdvancedQuery\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chr15k\\MeilisearchAdvancedQuery\\Tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chr15k\\MeilisearchAdvancedQuery\\MeilisearchAdvancedQueryServiceProvider"
            ]
        }
    },
    "scripts": {
        "refactor": "rector",
        "lint": "pint",
        "fix": ["@lint", "@refactor", "@lint"],
        "test:refactor": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always --coverage --parallel --min=100",
        "test": [
            "@test:refactor",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
